---
interface Props {
  title: string
  description?: string
}

const { title, description } = Astro.props

const components = [
  "button", "input", "card", "dialog", "dropdown-menu",
  "tabs", "select", "popover", "tooltip", "sheet",
  "accordion", "sonner", "sidebar", "skeleton", "command",
]
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title} - peace-ui</title>
    {description && <meta name="description" content={description} />}
    <style>
      * { margin: 0; padding: 0; box-sizing: border-box; }
      body {
        font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
        background: #09090b;
        color: #fafafa;
        line-height: 1.6;
      }
      a { color: inherit; text-decoration: none; }
      code {
        background: #1a1a2e;
        padding: 0.15em 0.4em;
        border-radius: 6px;
        font-size: 0.875em;
        font-family: "SF Mono", "Fira Code", monospace;
      }
      pre { background: #111; border-radius: 12px; padding: 1.25rem; overflow-x: auto; }
      pre code { background: none; padding: 0; }
      .layout { display: flex; min-height: 100vh; }
      .sidebar {
        width: 240px;
        border-right: 1px solid #1a1a2e;
        padding: 1.5rem 1rem;
        position: sticky;
        top: 0;
        height: 100vh;
        overflow-y: auto;
      }
      .sidebar-brand {
        font-weight: 700;
        font-size: 1.125rem;
        padding: 0 0.5rem 1.5rem;
        border-bottom: 1px solid #1a1a2e;
        margin-bottom: 1rem;
      }
      .sidebar-section { margin-bottom: 1.5rem; }
      .sidebar-section h3 {
        font-size: 0.75rem;
        text-transform: uppercase;
        letter-spacing: 0.05em;
        color: #71717a;
        padding: 0 0.5rem;
        margin-bottom: 0.5rem;
      }
      .sidebar-link {
        display: block;
        padding: 0.375rem 0.5rem;
        border-radius: 8px;
        font-size: 0.875rem;
        color: #a1a1aa;
        transition: all 0.15s;
      }
      .sidebar-link:hover { color: #fafafa; background: #1a1a2e; }
      .main { flex: 1; padding: 3rem; max-width: 800px; }
      .main h1 { font-size: 2rem; font-weight: 700; margin-bottom: 0.5rem; }
      .main h2 { font-size: 1.25rem; font-weight: 600; margin-top: 2rem; margin-bottom: 0.75rem; }
      .main p { color: #a1a1aa; margin-bottom: 1rem; }
      .install-cmd {
        background: #111;
        border: 1px solid #1a1a2e;
        border-radius: 12px;
        padding: 1rem 1.25rem;
        font-family: "SF Mono", "Fira Code", monospace;
        font-size: 0.875rem;
        margin: 1rem 0;
      }
      @media (max-width: 768px) {
        .sidebar { display: none; }
        .main { padding: 1.5rem; }
      }
    </style>
  </head>
  <body>
    <div class="layout">
      <nav class="sidebar">
        <div class="sidebar-brand">peace-ui</div>
        <div class="sidebar-section">
          <h3>Getting Started</h3>
          <a href="/docs/getting-started" class="sidebar-link">Installation</a>
        </div>
        <div class="sidebar-section">
          <h3>Components</h3>
          {components.map((name) => (
            <a href={`/docs/components/${name}`} class="sidebar-link">
              {name.split("-").map(w => w[0].toUpperCase() + w.slice(1)).join(" ")}
            </a>
          ))}
        </div>
      </nav>
      <main class="main">
        <slot />
      </main>
    </div>
  </body>
</html>
